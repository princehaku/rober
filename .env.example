# Remote cloud relay Docker/local proof placeholders.
# Copy to .env for local compose runs; never put real production secrets in git.

TRASHBOT_REMOTE_CLOUD_HOST=0.0.0.0
TRASHBOT_REMOTE_CLOUD_PORT=8088
TRASHBOT_REMOTE_CLOUD_PUBLISHED_PORT=8088
TRASHBOT_REMOTE_CLOUD_STATE=/data/remote_cloud_relay_state.json
TRASHBOT_REMOTE_CLOUD_STATE_BACKEND=file
TRASHBOT_REMOTE_CLOUD_BEARER_TOKEN=replace-with-local-dev-token

# Production preflight placeholders. Local HTTP must stay blocked until real TLS/public ingress exists.
TRASHBOT_REMOTE_CLOUD_PUBLIC_BASE_URL=http://127.0.0.1:8088
TRASHBOT_REMOTE_CLOUD_TLS_MODE=future_reverse_proxy
TRASHBOT_REMOTE_CLOUD_PUBLIC_INGRESS=missing

# Future OSS/CDN placeholders for snapshot/diagnostic objects; relay JSON API does not upload objects yet.
TRASHBOT_REMOTE_CLOUD_OSS_BUCKET=bytegallop
TRASHBOT_REMOTE_CLOUD_OSS_REGION=oss-cn-hangzhou
TRASHBOT_REMOTE_CLOUD_OSS_PREFIX=rober/<robot_id>/<date>/<task_id>/
TRASHBOT_REMOTE_CLOUD_CDN_BASE_URL=https://cdn.bytegallop.com/rober/
TRASHBOT_REMOTE_CLOUD_OSS_CREDENTIAL_MODE=placeholder

# SQLite proof can be enabled for single-node restart/reopen validation.
# It is still not production DB/queue, multi-instance, backup, or disaster-recovery evidence.
# TRASHBOT_REMOTE_CLOUD_STATE_BACKEND=sqlite
# TRASHBOT_REMOTE_CLOUD_STATE=/data/remote_cloud_relay_state.sqlite

# Optional local artifact path used only by preflight after a Docker/local
# backup/restore drill. It must not be treated as production backup policy.
# TRASHBOT_REMOTE_CLOUD_BACKUP_ARTIFACT=/tmp/remote_cloud_relay_backup.json

# Optional production store/queue gate artifact. This is Docker/local software proof only.
# It must not be treated as real production DB, queue, multi-instance, or disaster-recovery evidence.
# TRASHBOT_REMOTE_CLOUD_PRODUCTION_STORE_QUEUE_ARTIFACT=/tmp/trashbot_production_store_queue_gate.json
